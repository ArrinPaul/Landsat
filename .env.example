# Runtime
NODE_ENV=development

# Primary LLM provider (Gemini)
GEMINI_API_KEY=
# Optional alias used by some Genkit integrations
GOOGLE_GENAI_API_KEY=

# Fallback AI providers
GROQ_API_KEY=
MISTRAL_API_KEY=
HUGGINGFACE_API_KEY=

# Google Earth Engine / Firebase Admin credentials JSON (single-line JSON string)
GOOGLE_APPLICATION_CREDENTIALS_JSON=

# Phase 3 (GCP serverless orchestration)
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_REGION=us-central1
GCP_PIPELINE_TOPIC_PREFIX=earth-insights.pipeline
GCP_MONTHLY_BUDGET_USD=1200
GCP_DAILY_RUN_QUOTA=6
